# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ── Build output & release artifacts ────────────────────────────────────────
dist/
dist-ssr/
dist-electron/
release/

# Installer build resources (electron-builder `buildResources`). Track the
# resources, ignore the generated release-notes.md and placeholder.
build/*
!build/nsis/
!build/icon.ico
!build/installer.nsh
!build/license_en_US.txt
!build/license_ru_RU.txt

# ── Local secrets & environment ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime config (secrets & user state) ───────────────────────────────────
Backend/config/auth.config.json
Backend/config/translatorProxy.json
Backend/config/onboarding.json

# ── User-generated data ──────────────────────────────────────────────────────
Glossary/glossary_user.json

# ── C# build artifacts ───────────────────────────────────────────────────────
Backend/bin/
Backend/DllParser/bin/
Backend/DllParser/obj/

# ── MSC tool (released from the separate N1ko-Pro/ULTIMA_TOOLS repo; the exe is
#    downloaded at runtime to %APPDATA%/ULTIMA/tools/msc and never bundled).
#    We edit the tool SOURCE here, so track it but ignore all build output. ────
tools/MSC/*
!tools/MSC/*.cs
!tools/MSC/*.csproj
!tools/MSC/README.md
tools_src/

# ── MSC patcher (MSCLoc API). Source (src/, *.csproj, README, tests) is
#    tracked; build output and the large LOCAL-ONLY reference material (game
#    DLLs, MSCLoader binaries + source) are ignored. Released from ULTIMA_TOOLS.
tools/MSC-Patcher/bin/
tools/MSC-Patcher/obj/
tools/MSC-Patcher/tests/bin/
tools/MSC-Patcher/tests/obj/
tools/MSC-Patcher/Origin Files/
tools/MSC-Patcher/MSCLoader/
tools/MSC-Patcher/MSCModLoader-1.4.2/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── IDE & editor artifacts ───────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# ── Kiro local settings (contains secrets & machine-specific paths) ──────────
.kiro/settings/mcp.json

# ── Internal / private ───────────────────────────────────────────────────────
workspace/
.windsurf/
1.txt
