# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ── Build output & release artifacts ────────────────────────────────────────
dist/
dist-ssr/
dist-electron/
release/

# Installer build resources (electron-builder `buildResources`). Track the
# resources, ignore the generated release-notes.md and placeholder.
build/*
!build/nsis/
!build/icon.ico
!build/installer.nsh
!build/license_en_US.txt
!build/license_ru_RU.txt

# ── Local secrets & environment ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime config (secrets & user state) ───────────────────────────────────
Backend/config/auth.config.json
Backend/config/translatorProxy.json
Backend/config/onboarding.json

# ── User-generated data ──────────────────────────────────────────────────────
Glossary/glossary_user.json

# ── C# build artifacts ───────────────────────────────────────────────────────
Backend/bin/
Backend/DllParser/bin/
Backend/DllParser/obj/

# ── Tools ────────────────────────────────────────────────────────────────────
# Everything under tools/ is tracked in THIS repo (BG3 Divine binaries, the MSC
# C# tools, and tools/reference research material). The MSC tools are ALSO
# released to N1ko-Pro/ULTIMA_TOOLS via scripts/release-tool.js. Only build
# output and the transient release clone are ignored.
tools/**/bin/
tools/**/obj/
tools/**/publish/
tools/**/win-x64/
.ultima_tools_clone/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── IDE & editor artifacts ───────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# ── Kiro local settings (contains secrets & machine-specific paths) ──────────
.kiro/settings/mcp.json

# ── Internal / private ───────────────────────────────────────────────────────
workspace/
.windsurf/
1.txt
